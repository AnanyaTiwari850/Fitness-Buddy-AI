# ─────────────────────────────────────────────
#  IBM watsonx.ai Credentials
#  Copy this file to ".env" and fill in values.
# ─────────────────────────────────────────────

# IBM Cloud API Key (from IBM Cloud → Manage → Access → API Keys)
IBM_API_KEY=OtHU9lWb_mM9i0omMwyA0SWPrJ9KbDOprtw4-8cbJYA5

# watsonx.ai project ID  (from watsonx.ai → Projects → <your project> → Manage → General)
WATSONX_PROJECT_ID=c76e8fd5-fa65-4e64-acb4-68f20153233d


# watsonx.ai API URL  (region-specific; default is Dallas)
WATSONX_URL=https://jp-tok.ml.cloud.ibm.com

# Flask secret key  (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change_this_to_a_random_secret_key

# Flask environment  (development | production)
FLASK_ENV=development
